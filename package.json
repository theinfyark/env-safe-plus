{
  "name": "env-safe-plus",
  "version": "1.0.2",
  "description": "Tiny, typed environment variable validator with defaults, type coercion, and clear errors.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "types",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test tests/env.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "env",
    "environment",
    "validator",
    "process.env",
    "config",
    "dotenv",
    "schema",
    "type-safe"
  ],
  "author": "anilachary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theinfyark/env-safe-plus.git"
  },
  "bugs": {
    "url": "https://github.com/theinfyark/env-safe-plus/issues"
  },
  "homepage": "https://github.com/theinfyark/env-safe-plus#readme",
  "engines": {
    "node": ">=18"
  },
  "types": "./types/index.d.ts",
  "sideEffects": false,
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/anilachary"
  }
}
